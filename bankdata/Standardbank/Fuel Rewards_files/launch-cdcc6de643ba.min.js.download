source:"var curPagename = _satellite.getVar('pageName');\nvar curHostName = _satellite.getVar('hostName');\n/////////////////////UCOUNT START PIXEL IMPLEMENTATION///////////////////////////////////////////////////////////\nswitch(curPagename) {\n  case 'about ucount rewards:frequently asked questions':\n    \n     gtag_report_floodlight_conversion({\n        'allow_custom_scripts': true,\n       'send_to': 'DC-8448999/lp/ucoun00-+per_session'\n      });\n        break;\n    case 'about ucount rewards:getting started':\n     gtag_report_floodlight_conversion(\n     {\n       'allow_custom_scripts': true,\n        'send_to': 'DC-8448999/lp/ucoun008+per_session'\n     }); \n   break;\n   case 'about ucount rewards:how it works':\n     gtag_report_floodlight_conversion(\n     {\n       'allow_custom_scripts': true,\n      'send_to': 'DC-8448999/lp/ucoun007+per_session'\n       }); \n   break; \n   case 'about ucount rewards':\n     gtag_report_floodlight_conversion(\n     {\n       'allow_custom_scripts': true,\n       'send_to': 'DC-8448999/lp/ucoun00+per_session'\n     }); \n   break;\n   case 'about ucount rewards:qualifying products':\n     gtag_report_floodlight_conversion(\n     {\n       'allow_custom_scripts': true,\n       'send_to': 'DC-8448999/lp/ucoun009+per_session'\n     }); \n   break;\n   case 'caltex':\n     gtag_report_floodlight_conversion(\n     {\n       'allow_custom_scripts': true,\n      'send_to': 'DC-8448999/lp/ucoun006+per_session'\n     }); \n   break;\n   case 'collect':\n     gtag_report_floodlight_conversion(\n     {\n       'allow_custom_scripts': true,\n      'send_to': 'DC-8448999/lp/ucoun001+per_session'\n     }); \n   break; \n   case 'grocery rewards retailers':\n     gtag_report_floodlight_conversion(\n     {\n       'allow_custom_scripts': true,\n        'send_to': 'DC-8448999/lp/ucoun005+per_session'\n     }); \n   break;\n   case 'home':\n     gtag_report_floodlight_conversion(\n     {\n       'allow_custom_scripts': true,\n     