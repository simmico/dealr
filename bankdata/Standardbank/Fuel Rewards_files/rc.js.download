var callBackToken = function (response) {
	var formRecaptchaResponseItem = document.querySelectorAll(".g-recaptcha-response");
	if (formRecaptchaResponseItem) {
		for (var i = 0; i < formRecaptchaResponseItem.length; i++) {
			formRecaptchaResponseItem[i].value = response;
		}
	}
};
var resetReCaptchaToken = function () {
	var formRecaptchaResponseItem = document.querySelectorAll(".g-recaptcha-response");
	if (formRecaptchaResponseItem) {
		for (var i = 0; i < formRecaptchaResponseItem.length; i++) {
			formRecaptchaResponseItem[i].value = "";
		}
	}
};
var recaptchaError = function () {
	var formRecaptchaResponseItem = document.querySelectorAll(".g-recaptcha-response");
	if (formRecaptchaResponseItem) {
		for (var i = 0; i < formRecaptchaResponseItem.length; i++) {
			formRecaptchaResponseItem[i].value = "";
		}
	}
};

function restartReCaptcha() {
	if (grecaptcha) {
		grecaptcha.reset();
	}
}
var onloadCallback = function () {
	var captcha = document.querySelectorAll("#grecaptchaElement");
	if (captcha) {
		grecaptcha.render('grecaptchaElement', {
			'sitekey': '6LcvbB4UAAAAALE2i7bDyhZNYd9RU2ci5CxFdjB8',
			'expired-callback': resetReCaptchaToken,
			'callback': callBackToken,
			'error-callback': recaptchaError
		});
	}
};
